NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (no NEXT_PUBLIC_ prefix -- never sent to the browser). Bypasses
# Row Level Security; used by the mark-answers route to persist assignment
# attempts so students cannot write their own grades.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI-compatible AI provider
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_API_KEY=your-ai-provider-key

# Optional OpenRouter attribution
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AIDemic

# Text-to-speech (AI Podcasts). Defaults to OpenRouter's OpenAI-compatible
# /audio/speech endpoint. Falls back to AI_API_KEY if TTS_API_KEY is unset.
# Podcasts are a two-host dialogue -- TTS_VOICE is the host, TTS_VOICE_SECONDARY
# is the co-host. Both must be voices supported by the model -- for the default
# model that's Eve, Ara, Rex, Sal, or Leo.
TTS_BASE_URL=https://openrouter.ai/api/v1
TTS_MODEL=x-ai/grok-voice-tts-1.0
TTS_VOICE=Eve
TTS_VOICE_SECONDARY=Leo
TTS_API_KEY=
